{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Docker: Start Containers",
      "type": "shell",
      "command": "docker compose up -d",
      "cwd": "${workspaceFolder}",
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      "label": "Backend: Install Dependencies",
      "type": "shell",
      "command": "python -m pip install -r backend/requirements.txt",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Backend: Run FastAPI",
      "type": "shell",
      "command": "python -m uvicorn backend.main:app --reload",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Frontend: Install Dependencies",
      "type": "shell",
      "command": "npm install",
      "cwd": "${workspaceFolder}/frontend",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Frontend: Run Astro",
      "type": "shell",
      "command": "npm run dev",
      "cwd": "${workspaceFolder}/frontend",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Full Stack: Install All",
      "dependsOn": [
        "Backend: Install Dependencies",
        "Frontend: Install Dependencies"
      ],
      "group": "build"
    },
    {
      "label": "Docker: Stop Containers",
      "type": "shell",
      "command": "docker compose down",
      "cwd": "${workspaceFolder}",
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    {
      "label": "Docker: View Logs",
      "type": "shell",
      "command": "docker compose logs -f",
      "cwd": "${workspaceFolder}",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "isBackground": true,
      "problemMatcher": []
    }
  ]
}