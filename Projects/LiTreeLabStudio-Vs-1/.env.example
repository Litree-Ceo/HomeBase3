# LiTree Social - Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# FLASK CONFIGURATION
# ============================================
SECRET_KEY=your-secret-key-here-generate-a-random-string
FLASK_ENV=production
FLASK_DEBUG=false

# ============================================
# AZURE OPENAI CONFIGURATION
# Get from Azure Portal > Cognitive Services > Keys and Endpoint
# ============================================
OPENAI_API_KEY=your-azure-openai-key-here
OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
OPENAI_MODEL=litree-gpt35
AI_ENABLED=true

# ============================================
# AZURE APPLICATION INSIGHTS
# Get from Azure Portal > Application Insights > Overview
# ============================================
APPINSIGHTS_INSTRUMENTATIONKEY=your-insights-key
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=your-key;IngestionEndpoint=https://canadacentral-1.in.applicationinsights.azure.com/

# ============================================
# AZURE STORAGE (Optional - for file uploads)
# ============================================
AZURE_STORAGE_CONNECTION_STRING=your-storage-connection-string
AZURE_STORAGE_CONTAINER=uploads

# ============================================
# AZURE SQL DATABASE (Optional - for production)
# Use SQLite for dev, Azure SQL for production
# ============================================
# DATABASE_URL=postgresql://user:password@host:5432/database
# Or use SQLite (default):
DATABASE_URL=sqlite:///data/social.db

# ============================================
# RATE LIMITING
# ============================================
RATELIMIT_STORAGE_URL=memory://

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_REGISTRATION=true
ENABLE_FILE_UPLOAD=true
ENABLE_REALTIME_CHAT=true

# ============================================
# EMAIL (Optional - for notifications)
# ============================================
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
