# LiTLabS-OS Environment Configuration
# Use this for LOCAL development with all AI providers

# ============================================================
# AI PROVIDER SELECTION
# ============================================================
# Set to: openai, anthropic, google, deepseek, openrouter, or auto
AI_PROVIDER=openrouter

# ============================================================
# OPENAI (Option 1: Standard OpenAI)
# Get key from: https://platform.openai.com/api-keys
# ============================================================
OPENAI_API_KEY=your_openai_key_here

# ============================================================
# AZURE OPENAI (Option 2: Recommended for production/Azure integration)
# Get credentials from: https://portal.azure.com > OpenAI Service
# ============================================================
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-api-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
OPENAI_API_VERSION=2024-02-15-preview

# ============================================================
# ANTHROPIC (Option 3)
# Get key from: https://console.anthropic.com/
# ============================================================
ANTHROPIC_API_KEY=your_anthropic_key_here

# ============================================================
# GOOGLE GEMINI (Option 4)
# Get key from: https://ai.google.dev/
# ============================================================
GOOGLE_API_KEY=your-google-api-key

# ============================================================
# DEEPSEEK (Option 5: Most cost-effective)
# Get key from: https://platform.deepseek.com/
# ============================================================
DEEPSEEK_API_KEY=invalid

# ============================================================
# OPENROUTER (Option 6: Currently working - RECOMMENDED)
# Get key from: https://openrouter.ai/
# Provides unified access to 100+ models
# ============================================================
OPENROUTER_API_KEY=your_openrouter_key_here

# ============================================================
# AZURE CONFIGURATION
# ============================================================
# Application Insights for monitoring
APPINSIGHTS_INSTRUMENTATIONKEY=your-instrumentation-key
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=your-key

# ============================================================
# FLASK/FASTAPI CONFIGURATION
# ============================================================
# Environment: development, staging, production
ENVIRONMENT=development
LOG_LEVEL=INFO

# ============================================================
# CORS & SECURITY
# ============================================================
# Allowed origins for CORS (comma-separated)
CORS_ORIGINS=http://localhost:4321,http://localhost:3000,https://homebase3.app

# API Rate Limiting
RATE_LIMIT_PER_MINUTE=60
